---
import AppLayout from '../layouts/AppLayout.astro';
import { RecurringManager } from '../components/finance/RecurringManager';

---

<AppLayout title="Inflows - Life Panel" currentPath="/inflows">
  
  <header class="mb-8 mt-2">
    <h1 class="text-3xl font-serif text-platinum tracking-tight">Inflows</h1>
    <p class="text-platinum/50 mt-1 text-sm tracking-wide">Track predictable recurring revenue and monthly income sources.</p>
  </header>

  <section class="max-w-5xl">
    <RecurringManager type="inflow" client:load />
  </section>

</AppLayout>
