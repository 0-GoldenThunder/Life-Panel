---
import AppLayout from '../layouts/AppLayout.astro';
import { TransactionManager } from '../components/finance/TransactionManager';
import { ScopeHeader } from '../components/finance/ScopeHeader';

---

<AppLayout title="Business Ops - Life Panel">
  
  <header class="mb-8 mt-2">
    <h1 class="text-3xl font-serif text-platinum tracking-tight">Business Operations</h1>
    <p class="text-platinum/50 mt-1 text-sm tracking-wide">Monitor client retainers and operational costs.</p>
  </header>

  <section class="max-w-5xl">
    <ScopeHeader scope="business" client:load />
    
    <div class="mt-8">
      <h2 class="text-lg font-medium text-platinum mb-4">Business Ledger</h2>
      <TransactionManager forcedScope="business" client:load />
    </div>
  </section>

</AppLayout>
