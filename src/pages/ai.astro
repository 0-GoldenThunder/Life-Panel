---
export const prerender = false;
import AppLayout from '../layouts/AppLayout.astro';
import { AIAdvisor } from '../components/AIAdvisor';
import { BrainCircuit } from 'lucide-react';
---

<AppLayout title="AI Advisor — Life Panel">
  <div class="flex flex-col gap-8 max-w-4xl mx-auto w-full pt-8 pb-32 lg:pb-12">

    <header class="flex flex-col gap-2">
      <div class="flex items-center gap-3">
        <h1 class="text-3xl lg:text-4xl font-bold font-sans tracking-tight text-platinum flex items-center gap-3">
          AI Advisor
        </h1>
        <span class="bg-luxury-gold/20 text-luxury-gold text-xs font-bold px-2 py-1 rounded-md uppercase tracking-wider">Beta</span>
      </div>
      <p class="text-platinum/50 text-sm lg:text-base max-w-2xl">
        Your personal financial intelligence engine. Analyzes real data, surfaces critical risks, and recommends specific actions.
      </p>
    </header>

    <AIAdvisor client:load />

  </div>
</AppLayout>
