---
import AppLayout from '../layouts/AppLayout.astro';
import { EventCalendar } from '../components/events/EventCalendar';
import { TaskManager } from '../components/events/TaskManager';
---

<AppLayout title="Events, Goals & Tasks">
  <div class="flex flex-col gap-8 max-w-7xl mx-auto w-full pt-8 pb-32 lg:pb-12 h-full min-h-screen">
    
    <header class="flex flex-col gap-2">
      <h1 class="text-3xl lg:text-4xl font-serif text-platinum tracking-tight flex items-center gap-3">
        Events, Goals & Tasks
      </h1>
      <p class="text-platinum/50 text-sm lg:text-base max-w-2xl tracking-wide">
        Coordinate your schedules, active goals, and personal task checklists.
      </p>
    </header>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8 items-start">
      <div class="col-span-1 xl:col-span-2">
        <EventCalendar client:load />
      </div>
      <div class="col-span-1">
        <TaskManager client:load />
      </div>
    </div>
  </div>
</AppLayout>

