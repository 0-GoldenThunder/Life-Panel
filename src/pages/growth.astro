---
import AppLayout from '../layouts/AppLayout.astro';
import { GrowthAnalytics } from '../components/finance/GrowthAnalytics';

---

<AppLayout title="Growth Analytics - Life Panel" currentPath="/growth">
  
  <header class="mb-8 mt-2">
    <h1 class="text-3xl font-serif text-platinum tracking-tight">Growth & Analytics</h1>
    <p class="text-platinum/50 mt-1 text-sm tracking-wide">Visualize your financial trajectory and net worth over time.</p>
  </header>

  <section class="max-w-5xl">
    <GrowthAnalytics client:load />
  </section>

</AppLayout>
