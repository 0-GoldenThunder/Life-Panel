---
import AppLayout from '../layouts/AppLayout.astro';
import { TransactionManager } from '../components/finance/TransactionManager';
import { ScopeHeader } from '../components/finance/ScopeHeader';

---

<AppLayout title="Personal Finance - Life Panel" currentPath="/personal">
  
  <header class="mb-8 mt-2">
    <h1 class="text-3xl font-serif text-platinum tracking-tight">Personal Finance</h1>
    <p class="text-platinum/50 mt-1 text-sm tracking-wide">Manage your personal wallet and daily expenses.</p>
  </header>

  <section class="max-w-5xl">
    <ScopeHeader scope="personal" client:only="react" />
    
    <div class="mt-8">
      <h2 class="text-lg font-medium text-platinum mb-4">Personal Ledger</h2>
      <TransactionManager forcedScope="personal" client:only="react" />
    </div>
  </section>

</AppLayout>
