---
import Layout from '../layouts/Layout.astro';
import { LoginIsland } from '../components/LoginIsland';
import { UpdateToast } from '../components/UpdateToast';
---

<Layout title="Pro Max Life Manager">
  <main class="container mx-auto p-4 min-h-screen flex flex-col items-center justify-center">
    <div class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-serif text-platinum tracking-tight">
        Life <span class="text-luxury-gold">Manager</span>
      </h1>
    </div>
    
    <LoginIsland client:load />
    <UpdateToast client:load />
  </main>
</Layout>
