---
import AppLayout from '../layouts/AppLayout.astro';
import { TransactionManager } from '../components/finance/TransactionManager';

const today = new Date();
const dateString = today.toLocaleDateString(undefined, { weekday: 'long', day: 'numeric', month: 'long' });
---

<AppLayout title="Transactions - Life Panel" currentPath="/transactions">
  
  <header class="mb-8 mt-2 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-serif text-platinum tracking-tight">Master Ledger</h1>
      <p class="text-platinum/50 mt-1 text-sm tracking-wide">Manage all historical and current transactions.</p>
    </div>
  </header>

  <section class="max-w-5xl">
    <TransactionManager client:only="react" />
  </section>

</AppLayout>
