---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="A centralized, offline-first hub for task management and financial tracking." />
    <!-- Mobile Safe Area for Luxury Dock -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- PWA Manifest & Theme Color -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#050505" />

    <!-- Preconnect hints for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Load Playfair Display and Inter fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap&subset=latin" rel="stylesheet" />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-obsidian text-platinum antialiased min-h-screen">
    <slot />
  </body>
</html>
